# ─────────────────────────────────────────────────────────────────────────────
# My OS — environment variables
# Copy to `.env` and fill in. Validated by packages/shared/src/env.ts (zod).
# Vendor-standard names are kept as-is; app-specific vars are MYOS_-prefixed
# (see 08_Developer_Guidelines.md §2 / §7).
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# Core (required)
# Local dev via infra/compose.dev.yml uses these credentials.
DATABASE_URL=postgres://myos:myos@localhost:5432/myos
MYOS_APP_URL=http://localhost:3000

# Clerk authentication (Sprint 1.5). Create an app at https://dashboard.clerk.com
# and paste the keys below. Leave BOTH blank to run in local single-owner dev mode
# (no sign-in required). In production, set both. Only the IdentityService reads these.
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# AI providers (Sprint 5.3 — optional; features degrade to the deterministic Local
# provider when unset; see 06_AI_Architecture.md §1 / NFR-9). Server-side ONLY — never
# exposed to the browser, never logged. A provider activates only when its key is set;
# the Local provider is always the offline fallback. Paste your keys in your local .env
# (gitignored), NOT here. Rotate any key that has been shared in plain text.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
VOYAGE_API_KEY=
# 32+ char secret used to encrypt provider_credentials at rest. Generate: openssl rand -base64 48
MYOS_AI_CREDENTIALS_SECRET=

# Connector Platform (Sprint 6.4). 32+ char secret used to encrypt connector_credentials at rest
# with AES-256-GCM. DISTINCT from the AI secret — connector credentials are isolated from the AI
# subsystem and never reachable by any AI provider. When unset, connectors run in deterministic
# offline mode (no live OAuth). Generate: openssl rand -base64 48
MYOS_CONNECTOR_SECRET=

# Web Push / VAPID (optional). Generate: npx web-push generate-vapid-keys
# Set NEXT_PUBLIC_MYOS_VAPID_PUBLIC_KEY to the SAME value as MYOS_VAPID_PUBLIC_KEY —
# the browser needs the public key to create a push subscription (Sprint 1.7).
MYOS_VAPID_PUBLIC_KEY=
MYOS_VAPID_PRIVATE_KEY=
MYOS_VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_MYOS_VAPID_PUBLIC_KEY=

# Backups (optional — S3-compatible bucket; see 05_Database_Design.md §16).
MYOS_BACKUP_S3_ENDPOINT=
MYOS_BACKUP_S3_BUCKET=
MYOS_BACKUP_S3_ACCESS_KEY=
MYOS_BACKUP_S3_SECRET_KEY=
MYOS_BACKUP_AGE_PUBLIC_KEY=

# Deployment (used by infra/docker-compose.yml + Caddy)
MYOS_DOMAIN=localhost

# Postgres container (infra compose only)
POSTGRES_USER=myos
POSTGRES_PASSWORD=myos
POSTGRES_DB=myos
