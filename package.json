{
  "name": "myos",
  "version": "1.0.0-rc.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,css,yml,yaml}\"",
    "db:generate": "pnpm --filter @myos/db generate",
    "db:migrate": "pnpm --filter @myos/db migrate",
    "db:studio": "pnpm --filter @myos/db studio",
    "db:check": "pnpm --filter @myos/db check",
    "db:seed": "pnpm --filter @myos/db seed",
    "worker:dev": "pnpm --filter @myos/worker dev",
    "prepare": "husky",
    "audit": "node scripts/repository-audit.mjs",
    "audit:exports": "node scripts/export-validator.mjs",
    "audit:migrations": "node scripts/migration-validator.mjs",
    "audit:packages": "node scripts/package-health.mjs",
    "audit:docs": "node scripts/docs-validator.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
